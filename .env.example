# ShopMate environment — copy to .env and fill in values

# Telegram (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# OpenAI (required for AI replies and vision)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your_random_verify_token_32_chars_min
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

# Database
DATABASE_URL=sqlite:///shopmate.db

# Business defaults
DEFAULT_BUSINESS_ID=techlink_mobile
DEFAULT_TIMEZONE=Africa/Accra
DEFAULT_LANGUAGE=en

# Morning digest (owner summary)
DIGEST_HOUR=8
DIGEST_MINUTE=0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Handoff keyword
HUMAN_HANDOFF_KEYWORD=HUMAN
